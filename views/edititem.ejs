<!DOCTYPE html>

<html>

    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Edit task</title>
        <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect width='24' height='24' rx='6' fill='%237c5cff'/%3E%3Cpath d='M7 12l3 3 7-7' stroke='white' stroke-width='2.2' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E" />
        <link rel="stylesheet" href="/styles.css" />
    </head>

    <body class="page-shell">
        <main class="app-card compact-card">
            <header class="hero hero-small">
                <div class="hero-text">
                    <p class="eyebrow">Update item</p>
                    <h1>Edit task</h1>
                    <p class="hero-copy">Refine the wording or replace the item completely.</p>
                </div>
                <div class="brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4 20l.9-3.6L15.4 6a1.5 1.5 0 0 1 2.1 0l.5.5a1.5 1.5 0 0 1 0 2.1L7.6 19.1 4 20Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </div>
            </header>

            <section class="todo-panel">
                <form class="todo-form" action="/todo/edit/<%= todoIdx %>" method="post">
                    <label for="editTodo">Change this task</label>
                    <input type="hidden" name="_method" value="PUT">
                    <div class="form-row stacked">
                        <input type="text" name="editTodo" id="editTodo" autofocus placeholder="<%- todo %>" value="<%- todo %>" />
                        <div class="action-row">
                            <a class="ghost-button" href="/todo">Cancel</a>
                            <input type="submit" value="Save changes" />
                        </div>
                    </div>
                </form>
            </section>
        </main>
    </body>

</html>
